#SOMENTE EM PRODUÇÃO
# EasyPanel (provisionamento de subdomínio: domínio + tunnel DNS)
EASYPANEL_API_URL=
EASYPANEL_EMAIL=
EASYPANEL_PASSWORD=

# createDomain: path, certificado, https, wildcard (opcionais)
EASYPANEL_DOMAIN_PATH=/
EASYPANEL_DOMAIN_CERTIFICATE_RESOLVER=
EASYPANEL_DOMAIN_HTTPS=true
EASYPANEL_DOMAIN_WILDCARD=false
MAIN_DOMAIN=localhost

# se for true ele n cria o subdomínio no EasyPanel e Cloudflare.
PROVISION_SUBDOMAIN_IN_NON_PRODUCTION=true 


# serviceDestination.composeService: API exige string (use "" se não precisar)
EASYPANEL_DOMAIN_COMPOSE_SERVICE=
# Tunnel (cloudflareTunnel.createTunnelRule) – zoneId e domain vêm de GET cloudflareTunnel.listZones (primeiro item)
# Em produção o tenant é criado como sub do subdomínio base: third_level.base.domain.com (ex: empresa.app.eyiservicos.com.br)
EASYPANEL_TUNNEL_BASE_SUBDOMAIN=app
EASYPANEL_TUNNEL_PROJECT_NAME=
EASYPANEL_TUNNEL_SERVICE_NAME=
EASYPANEL_TUNNEL_PATH=/
EASYPANEL_TUNNEL_INTERNAL_PROTOCOL=http
EASYPANEL_TUNNEL_INTERNAL_PORT=0